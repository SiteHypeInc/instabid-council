        "responseBody": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>InstaBid AI Council</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,600;1,400&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/marked@12/marked.min.js\"></script>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  html, body { height: 100%; }\n  body {\n    font-family: 'Inter', system-ui, sans-serif;\n    background: #0a0e1a;\n    color: #e2e8f0;\n    line-height: 1.6;\n    font-size: 15px;\n    min-height: 100vh;\n    background-image: radial-gradient(circle at 20% 0%, rgba(37, 99, 235, 0.08) 0%, transparent 50%),\n                      radial-gradient(circle at 80% 100%, rgba(217, 119, 87, 0.05) 0%, transparent 50%);\n    overflow-x: hidden;\n  }\n\n  /* App shell */\n  .app {\n    display: grid;\n    grid-template-columns: 280px 1fr;\n    min-height: 100vh;\n    max-width: 1440px;\n    margin: 0 auto;\n  }\n  @media (max-width: 900px) {\n    .app { grid-template-columns: 1fr; }\n  }\n\n  /* Sidebar */\n  .sidebar {\n    background: #07091a;\n    border-right: 1px solid #1e293b;\n    padding: 1.5rem 1rem;\n    display: flex;\n    flex-direction: column;\n    position: sticky;\n    top: 0;\n    height: 100vh;\n    overflow-y: auto;\n  }\n  @media (max-width: 900px) {\n    .sidebar {\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 280px;\n      z-index: 50;\n      transform: translateX(-100%);\n      transition: transform 0.25s ease;\n      box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);\n    }\n    .sidebar.open { transform: translateX(0); }\n  }\n\n  .sidebar-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding-bottom: 1rem;\n    border-bottom: 1px solid #1e293b;\n    margin-bottom: 1rem;\n  }\n  .sidebar-title {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.18em;\n    color: #64748b;\n    font-weight: 700;\n  }\n  .new-btn {\n    background: linear-gradient(135deg, #3b82f6, #2563eb);\n    color: white;\n    border: none;\n    padding: 0.35rem 0.75rem;\n    border-radius: 5px;\n    font-weight: 600;\n    font-size: 0.78rem;\n    cursor: pointer;\n    transition: all 0.15s;\n    font-family: inherit;\n  }\n  .new-btn:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(37, 99, 235, 0.4); }\n\n  .thread-list { flex-grow: 1; overflow-y: auto; }\n  .thread-item {\n    padding: 0.8rem 0.85rem;\n    margin-bottom: 0.4rem;\n    border-radius: 6px;\n    cursor: pointer;\n    border: 1px solid transparent;\n    transition: background 0.15s, border-color 0.15s;\n    position: relative;\n  }\n  .thread-item:hover { background: #0f1424; border-color: #1e293b; }\n  .thread-item.active { background: #131a2e; border-color: #3b82f6; }\n  .thread-item .question-preview {\n    font-size: 0.85rem;\n    color: #cbd5e1;\n    line-height: 1.4;\n    margin-bottom: 0.3rem;\n    overflow: hidden;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n  }\n  .thread-item.active .question-preview { color: #f1f5f9; font-weight: 500; }\n  .thread-item.in-progress .question-preview::after {\n    content: ' \u25cf';\n    color: #3b82f6;\n    animation: pulse 1.4s infinite;\n  }\n  .thread-item .meta {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.66rem;\n    color: #64748b;\n    letter-spacing: 0.03em;\n  }\n  .thread-item .actions {\n    display: none;\n    gap: 0.25rem;\n  }\n  .thread-item:hover .actions, .thread-item.active .actions { display: flex; }\n  .thread-item .action-btn {\n    background: transparent;\n    border: none;\n    color: #64748b;\n    cursor: pointer;\n    padding: 0.2rem 0.35rem;\n    border-radius: 3px;\n    font-size: 0.78rem;\n    transition: all 0.15s;\n    font-family: inherit;\n  }\n  .thread-item .action-btn:hover { background: #1e293b; color: #cbd5e1; }\n  .thread-item .action-btn.delete:hover { background: #7f1d1d; color: #fecaca; }\n\n  .empty-list {\n    text-align: center;\n    padding: 2rem 1rem;\n    color: #475569;\n    font-size: 0.85rem;\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .sidebar-footer {\n    padding-top: 1rem;\n    border-top: 1px solid #1e293b;\n    margin-top: 1rem;\n  }\n  .session-info {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.65rem;\n    color: #475569;\n    letter-spacing: 0.05em;\n    text-align: center;\n  }\n  .live-dot {\n    display: inline-block;\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n    margin-right: 0.3rem;\n    background: #10b981;\n    box-shadow: 0 0 8px #10b981;\n  }\n\n  /* Mobile sidebar toggle */\n  .sidebar-toggle {\n    display: none;\n    position: fixed;\n    top: 1rem;\n    left: 1rem;\n    z-index: 60;\n    background: #131826;\n    border: 1px solid #334155;\n    color: #e2e8f0;\n    width: 40px;\n    height: 40px;\n    border-radius: 6px;\n    cursor: pointer;\n    font-size: 1.1rem;\n    align-items: center;\n    justify-content: center;\n  }\n  @media (max-width: 900px) { .sidebar-toggle { display: flex; } }\n  .sidebar-overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0, 0, 0, 0.5);\n    z-index: 40;\n  }\n  .sidebar-overlay.open { display: block; }\n\n  /* Main area */\n  .main {\n    padding: 2rem 2.5rem 4rem;\n    min-width: 0; /* prevents grid item from overflowing */\n  }\n  @media (max-width: 900px) {\n    .main { padding: 4rem 1rem 4rem; }\n  }\n\n  .masthead {\n    border-bottom: 1px solid #1e293b;\n    padding-bottom: 1.25rem;\n    margin-bottom: 1.5rem;\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n    flex-wrap: wrap;\n    gap: 1rem;\n  }\n  .title {\n    font-family: 'Newsreader', serif;\n    font-weight: 600;\n    font-size: 1.85rem;\n    color: #f8fafc;\n    letter-spacing: -0.01em;\n    line-height: 1.1;\n  }\n  .tagline {\n    font-size: 0.82rem;\n    color: #94a3b8;\n    margin-top: 0.3rem;\n  }\n\n  /* Input area */\n  .input-area {\n    background: #0f1420;\n    border: 1px solid #1e293b;\n    border-radius: 8px;\n    padding: 1rem;\n    margin-bottom: 1.25rem;\n    transition: border-color 0.2s;\n  }\n  .input-area:focus-within { border-color: #3b82f6; }\n  textarea#question {\n    width: 100%;\n    background: transparent;\n    border: none;\n    color: #f1f5f9;\n    font-family: 'Inter', sans-serif;\n    font-size: 1rem;\n    line-height: 1.5;\n    resize: vertical;\n    min-height: 56px;\n    outline: none;\n  }\n  textarea#question::placeholder { color: #475569; }\n  .input-controls {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-top: 0.65rem;\n    padding-top: 0.65rem;\n    border-top: 1px solid #1e293b;\n    flex-wrap: wrap;\n    gap: 0.5rem;\n  }\n  .input-hint {\n    font-size: 0.7rem;\n    color: #64748b;\n    font-family: 'JetBrains Mono', monospace;\n  }\n  button#send {\n    background: linear-gradient(135deg, #3b82f6, #2563eb);\n    color: white;\n    border: none;\n    padding: 0.5rem 1.3rem;\n    border-radius: 6px;\n    font-weight: 600;\n    font-size: 0.88rem;\n    cursor: pointer;\n    transition: all 0.15s;\n    font-family: inherit;\n  }\n  button#send:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4); }\n  button#send:disabled { background: #1e293b; color: #475569; cursor: not-allowed; transform: none; box-shadow: none; }\n\n  /* Loading bar */\n  .loading {\n    display: none;\n    align-items: center;\n    gap: 0.7rem;\n    padding: 0.85rem 1.1rem;\n    background: #0f1420;\n    border: 1px solid #1e293b;\n    border-radius: 8px;\n    margin-bottom: 1rem;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.8rem;\n    color: #94a3b8;\n  }\n  .loading.active { display: flex; }\n  .loading .pulse {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    background: #3b82f6;\n    animation: pulse 1.4s infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 0.4; transform: scale(0.9); }\n    50% { opacity: 1; transform: scale(1.1); }\n  }\n  .loading .elapsed { margin-left: auto; color: #64748b; font-size: 0.74rem; }\n\n  /* Answer header (shows the question being answered) */\n  .answer-header {\n    display: none;\n    background: #0f1420;\n    border: 1px solid #1e293b;\n    border-left: 3px solid #3b82f6;\n    border-radius: 6px;\n    padding: 0.85rem 1.1rem;\n    margin-bottom: 1.25rem;\n    position: relative;\n  }\n  .answer-header.active { display: block; }\n  .answer-header .label {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.65rem;\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    color: #64748b;\n    margin-bottom: 0.3rem;\n  }\n  .answer-header .q {\n    color: #e2e8f0;\n    font-size: 0.93rem;\n    font-style: italic;\n    line-height: 1.4;\n    padding-right: 6rem;\n  }\n  .answer-header .header-actions {\n    position: absolute;\n    top: 0.85rem;\n    right: 1rem;\n    display: flex;\n    gap: 0.4rem;\n  }\n  .answer-header .header-actions button {\n    background: #131826;\n    border: 1px solid #334155;\n    color: #94a3b8;\n    padding: 0.3rem 0.6rem;\n    border-radius: 5px;\n    font-size: 0.72rem;\n    cursor: pointer;\n    transition: all 0.15s;\n    font-family: inherit;\n  }\n  .answer-header .header-actions button:hover { border-color: #64748b; color: #e2e8f0; background: #1e293b; }\n\n  /* Error */\n  .error-card {\n    background: rgba(239, 68, 68, 0.08);\n    border: 1px solid #7f1d1d;\n    border-radius: 8px;\n    padding: 1rem 1.25rem;\n    color: #fca5a5;\n    margin-bottom: 1rem;\n    font-size: 0.88rem;\n    display: none;\n  }\n  .error-card.active { display: block; }\n\n  /* Empty state */\n  .empty-state {\n    text-align: center;\n    padding: 5rem 2rem;\n    color: #475569;\n  }\n  .empty-state .icon { font-size: 3rem; margin-bottom: 0.75rem; opacity: 0.4; }\n  .empty-state .text {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.82rem;\n    letter-spacing: 0.02em;\n    margin-bottom: 0.4rem;\n  }\n  .empty-state .sub {\n    font-size: 0.8rem;\n    color: #334155;\n    font-style: italic;\n  }\n  .empty-state.hidden { display: none; }\n\n  /* Results sections */\n  .results { display: none; }\n  .results.active { display: block; }\n\n  .section-label {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.68rem;\n    text-transform: uppercase;\n    letter-spacing: 0.18em;\n    color: #64748b;\n    margin: 1.75rem 0 0.65rem;\n    font-weight: 600;\n  }\n  .section-label:first-child { margin-top: 0.5rem; }\n\n  /* Consensus card */\n  .consensus-card {\n    background: linear-gradient(135deg, rgba(251, 191, 36, 0.05), rgba(245, 158, 11, 0.02));\n    border: 1px solid #78350f;\n    border-left: 3px solid #fbbf24;\n    border-radius: 8px;\n    padding: 1.5rem 1.75rem;\n    margin-bottom: 1.25rem;\n  }\n  .consensus-card .badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.4rem;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    color: #fbbf24;\n    font-weight: 700;\n    margin-bottom: 0.75rem;\n  }\n  .consensus-card .content {\n    color: #f8fafc;\n    font-size: 0.98rem;\n    line-height: 1.7;\n  }\n  .consensus-card .content strong { color: #fde68a; font-weight: 600; }\n  .consensus-card .content p { margin-bottom: 0.7rem; }\n  .consensus-card .content p:last-child { margin-bottom: 0; }\n  .consensus-card .content ul, .consensus-card .content ol { margin: 0.4rem 0 0.6rem 1.4rem; }\n  .consensus-card .content li { margin-bottom: 0.3rem; }\n  .consensus-card .content code {\n    background: rgba(251, 191, 36, 0.1);\n    color: #fde68a;\n    padding: 0.1rem 0.32rem;\n    border-radius: 3px;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.88em;\n  }\n\n  /* Dissent card */\n  .dissent-card {\n    background: rgba(239, 68, 68, 0.04);\n    border: 1px solid #7f1d1d;\n    border-left: 3px solid #ef4444;\n    border-radius: 8px;\n    padding: 1.35rem 1.6rem;\n    margin-bottom: 1.25rem;\n  }\n  .dissent-card .badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.4rem;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    color: #fca5a5;\n    font-weight: 700;\n    margin-bottom: 0.65rem;\n  }\n  .dissent-card .content { color: #fecaca; font-size: 0.92rem; }\n  .dissent-card .content strong { color: #fee2e2; font-weight: 600; }\n  .dissent-card .content ul { margin-left: 1.3rem; }\n  .dissent-card .content li { margin-bottom: 0.4rem; }\n  .dissent-card .content p { margin-bottom: 0.45rem; }\n\n  /* Model grid */\n  .models-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 0.85rem;\n  }\n  @media (min-width: 1100px) {\n    .models-grid { grid-template-columns: repeat(4, 1fr); }\n  }\n\n  .model-card {\n    background: #131826;\n    border: 1px solid #1e293b;\n    border-radius: 8px;\n    padding: 1rem 1.15rem;\n    transition: border-color 0.2s, transform 0.2s;\n    display: flex;\n    flex-direction: column;\n  }\n  .model-card:hover { transform: translateY(-2px); }\n  .model-card .header {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding-bottom: 0.55rem;\n    border-bottom: 1px solid #1e293b;\n    margin-bottom: 0.7rem;\n  }\n  .model-card .swatch { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }\n  .model-card .name { font-weight: 600; font-size: 0.88rem; color: #f1f5f9; letter-spacing: -0.01em; }\n  .model-card .vendor {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.62rem;\n    color: #64748b;\n    margin-left: auto;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n  }\n  .model-card .content {\n    font-size: 0.85rem;\n    color: #cbd5e1;\n    line-height: 1.6;\n    flex-grow: 1;\n  }\n  .model-card .content p { margin-bottom: 0.45rem; }\n  .model-card .content code {\n    background: rgba(148, 163, 184, 0.1);\n    padding: 0.1rem 0.3rem;\n    border-radius: 3px;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 0.85em;\n  }\n  .model-card .content strong { color: #f1f5f9; }\n  .model-card .content ul, .model-card .content ol { margin: 0.35rem 0 0.55rem 1.1rem; }\n  .model-card .content li { margin-bottom: 0.25rem; }\n\n  .model-card.claude { border-color: #7c2d12; }\n  .model-card.claude:hover { border-color: #D97757; }\n  .model-card.claude .swatch { background: #D97757; }\n  .model-card.claude .vendor { color: #D97757; }\n\n  .model-card.gpt { border-color: #064e3b; }\n  .model-card.gpt:hover { border-color: #10A37F; }\n  .model-card.gpt .swatch { background: #10A37F; }\n  .model-card.gpt .vendor { color: #10A37F; }\n\n  .model-card.gemini { border-color: #1e3a8a; }\n  .model-card.gemini:hover { border-color: #4285F4; }\n  .model-card.gemini .swatch { background: #4285F4; }\n  .model-card.gemini .vendor { color: #4285F4; }\n\n  .model-card.grok { border-color: #4c1d95; }\n  .model-card.grok:hover { border-color: #a78bfa; }\n  .model-card.grok .swatch { background: #a78bfa; }\n  .model-card.grok .vendor { color: #a78bfa; }\n\n  /* Markdown overrides */\n  .content h3 { font-size: 0.98rem; margin: 0.9rem 0 0.35rem; color: #f1f5f9; }\n  .content h4 { font-size: 0.92rem; margin: 0.7rem 0 0.3rem; color: #e2e8f0; }\n  .content hr { border: none; border-top: 1px solid #1e293b; margin: 0.9rem 0; }\n\n  /* Toast */\n  .toast {\n    position: fixed;\n    bottom: 1.5rem;\n    right: 1.5rem;\n    background: #131826;\n    border: 1px solid #334155;\n    color: #f1f5f9;\n    padding: 0.7rem 1.1rem;\n    border-radius: 6px;\n    font-size: 0.85rem;\n    z-index: 100;\n    transform: translateY(120%);\n    transition: transform 0.25s ease;\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);\n  }\n  .toast.show { transform: translateY(0); }\n  .toast.success { border-color: #166534; color: #bbf7d0; }\n</style>\n</head>\n<body>\n\n<button class=\"sidebar-toggle\" id=\"sidebar-toggle\" title=\"Toggle threads\">\u2630</button>\n<div class=\"sidebar-overlay\" id=\"sidebar-overlay\"></div>\n\n<div class=\"app\">\n\n  <aside class=\"sidebar\" id=\"sidebar\">\n    <div class=\"sidebar-header\">\n      <span class=\"sidebar-title\">Threads</span>\n      <button class=\"new-btn\" id=\"new-btn\">+ New</button>\n    </div>\n    <div class=\"thread-list\" id=\"thread-list\">\n      <div class=\"empty-list\">No threads yet. Ask a question.</div>\n    </div>\n    <div class=\"sidebar-footer\">\n      <div class=\"session-info\">\n        <span class=\"live-dot\"></span>WEBHOOK LIVE \u00b7 <span id=\"session-id\">\u2014</span>\n      </div>\n    </div>\n  </aside>\n\n  <main class=\"main\">\n    <div class=\"masthead\">\n      <div>\n        <h1 class=\"title\">InstaBid AI Council</h1>\n        <div class=\"tagline\">Four frontier models answer in parallel \u00b7 Opus 4.7 synthesizes</div>\n      </div>\n    </div>\n\n    <div class=\"input-area\">\n      <textarea id=\"question\" placeholder=\"Ask the council...\"></textarea>\n      <div class=\"input-controls\">\n        <span class=\"input-hint\">\u2318 + Enter to send</span>\n        <button id=\"send\">Send to Council</button>\n      </div>\n    </div>\n\n    <div class=\"loading\" id=\"loading\">\n      <div class=\"pulse\"></div>\n      <span id=\"loading-status\">Routing to four models...</span>\n      <span class=\"elapsed\" id=\"elapsed\">0.0s</span>\n    </div>\n\n    <div class=\"error-card\" id=\"error\"></div>\n\n    <div class=\"empty-state\" id=\"empty\">\n      <div class=\"icon\">\u2696</div>\n      <div class=\"text\">ASK A STRATEGIC QUESTION</div>\n      <div class=\"sub\">Four perspectives \u00b7 synthesized \u00b7 saved to your thread</div>\n    </div>\n\n    <div class=\"answer-header\" id=\"answer-header\">\n      <div class=\"label\">Question</div>\n      <div class=\"q\" id=\"answer-question\"></div>\n      <div class=\"header-actions\">\n        <button id=\"copy-btn\" title=\"Copy as markdown\">\u29c9 Copy</button>\n        <button id=\"download-btn\" title=\"Download as .md\">\u2193 MD</button>\n      </div>\n    </div>\n\n    <div class=\"results\" id=\"results\">\n\n      <div class=\"section-label\">Synthesis</div>\n      <div class=\"consensus-card\">\n        <div class=\"badge\">\u25b6 Consensus</div>\n        <div class=\"content\" id=\"consensus-content\"></div>\n      </div>\n\n      <div class=\"section-label\" id=\"dissent-label\" style=\"display:none\">Disagreements</div>\n      <div class=\"dissent-card\" id=\"dissent-card\" style=\"display:none\">\n        <div class=\"badge\">\u26a0 Dissent Flags</div>\n        <div class=\"content\" id=\"dissent-content\"></div>\n      </div>\n\n      <div class=\"section-label\">Raw Model Answers</div>\n      <div class=\"models-grid\" id=\"models-grid\">\n        <div class=\"model-card claude\">\n          <div class=\"header\"><div class=\"swatch\"></div><div class=\"name\">Claude Opus 4.7</div><div class=\"vendor\">Anthropic</div></div>\n          <div class=\"content\" id=\"claude-content\"><em style=\"color:#475569\">waiting...</em></div>\n        </div>\n        <div class=\"model-card gpt\">\n          <div class=\"header\"><div class=\"swatch\"></div><div class=\"name\">GPT-5.1</div><div class=\"vendor\">OpenAI</div></div>\n          <div class=\"content\" id=\"gpt-content\"><em style=\"color:#475569\">waiting...</em></div>\n        </div>\n        <div class=\"model-card gemini\">\n          <div class=\"header\"><div class=\"swatch\"></div><div class=\"name\">Gemini 3.1 Pro</div><div class=\"vendor\">Google</div></div>\n          <div class=\"content\" id=\"gemini-content\"><em style=\"color:#475569\">waiting...</em></div>\n        </div>\n        <div class=\"model-card grok\">\n          <div class=\"header\"><div class=\"swatch\"></div><div class=\"name\">Grok 4.3</div><div class=\"vendor\">xAI</div></div>\n          <div class=\"content\" id=\"grok-content\"><em style=\"color:#475569\">waiting...</em></div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n\n</div>\n\n<div class=\"toast\" id=\"toast\"></div>\n\n<script>\n  const WEBHOOK_URL = 'https://n8n.instabid.pro/webhook/c7d2751c-ef7c-4e30-9df7-d865700602e9/chat';\n\n  // Session ID (persistent)\n  let sessionId = localStorage.getItem('council_session_id');\n  if (!sessionId) {\n    sessionId = 'sess-' + Math.random().toString(36).slice(2, 10) + '-' + Date.now().toString(36);\n    localStorage.setItem('council_session_id', sessionId);\n  }\n  document.getElementById('session-id').textContent = sessionId.split('-')[1].toUpperCase();\n\n  // Thread storage\n  function loadThreads() {\n    try { return JSON.parse(localStorage.getItem('council_threads') || '[]'); }\n    catch (e) { return []; }\n  }\n  function saveThreads(t) { localStorage.setItem('council_threads', JSON.stringify(t)); }\n\n  let threads = loadThreads();\n  let activeThreadId = null;\n\n  // Element refs\n  const $threadList = document.getElementById('thread-list');\n  const $question = document.getElementById('question');\n  const $send = document.getElementById('send');\n  const $newBtn = document.getElementById('new-btn');\n  const $loading = document.getElementById('loading');\n  const $status = document.getElementById('loading-status');\n  const $elapsed = document.getElementById('elapsed');\n  const $error = document.getElementById('error');\n  const $empty = document.getElementById('empty');\n  const $results = document.getElementById('results');\n  const $answerHeader = document.getElementById('answer-header');\n  const $answerQ = document.getElementById('answer-question');\n  const $copyBtn = document.getElementById('copy-btn');\n  const $downloadBtn = document.getElementById('download-btn');\n  const $consensus = document.getElementById('consensus-content');\n  const $dissentLabel = document.getElementById('dissent-label');\n  const $dissentCard = document.getElementById('dissent-card');\n  const $dissent = document.getElementById('dissent-content');\n  const $claude = document.getElementById('claude-content');\n  const $gpt = document.getElementById('gpt-content');\n  const $gemini = document.getElementById('gemini-content');\n  const $grok = document.getElementById('grok-content');\n  const $sidebar = document.getElementById('sidebar');\n  const $sidebarOverlay = document.getElementById('sidebar-overlay');\n  const $sidebarToggle = document.getElementById('sidebar-toggle');\n  const $toast = document.getElementById('toast');\n\n  marked.setOptions({ breaks: true, gfm: true });\n\n  // Helpers\n  function formatRelative(ts) {\n    const diff = Date.now() - ts;\n    const s = Math.floor(diff / 1000);\n    if (s < 60) return s + 's ago';\n    const m = Math.floor(s / 60);\n    if (m < 60) return m + 'm ago';\n    const h = Math.floor(m / 60);\n    if (h < 24) return h + 'h ago';\n    const d = Math.floor(h / 24);\n    return d + 'd ago';\n  }\n  function showToast(msg, kind) {\n    $toast.textContent = msg;\n    $toast.className = 'toast ' + (kind || '') + ' show';\n    setTimeout(() => $toast.classList.remove('show'), 2200);\n  }\n  function uid() { return 't-' + Math.random().toString(36).slice(2, 8) + Date.now().toString(36).slice(-4); }\n\n  // Parse the structured markdown response\n  function parseResponse(text) {\n    const result = { consensus: '', dissent: '', raw: {} };\n    const parts = text.split(/^## /m).filter(p => p.trim());\n    for (const part of parts) {\n      const lines = part.split('\\n');\n      const headerLine = lines[0].toLowerCase().trim();\n      const body = lines.slice(1).join('\\n').trim();\n      if (headerLine.startsWith('consensus')) result.consensus = body;\n      else if (headerLine.startsWith('dissent')) result.dissent = body;\n      else if (headerLine.startsWith('raw')) {\n        const modelParts = body.split(/^### /m).filter(p => p.trim());\n        for (const mp of modelParts) {\n          const mlines = mp.split('\\n');\n          const modelName = mlines[0].toLowerCase().trim();\n          const modelBody = mlines.slice(1).join('\\n').trim();\n          if (modelName.includes('claude')) result.raw.claude = modelBody;\n          else if (modelName.includes('gpt')) result.raw.gpt = modelBody;\n          else if (modelName.includes('gemini')) result.raw.gemini = modelBody;\n          else if (modelName.includes('grok')) result.raw.grok = modelBody;\n        }\n      }\n    }\n    return result;\n  }\n\n  function renderAnswer(text) {\n    const parsed = parseResponse(text);\n    $consensus.innerHTML = parsed.consensus ? marked.parse(parsed.consensus) : '<em style=\"color:#475569\">no consensus produced</em>';\n    if (parsed.dissent && parsed.dissent.trim()) {\n      $dissentLabel.style.display = 'block';\n      $dissentCard.style.display = 'block';\n      $dissent.innerHTML = marked.parse(parsed.dissent);\n    } else {\n      $dissentLabel.style.display = 'none';\n      $dissentCard.style.display = 'none';\n    }\n    $claude.innerHTML = parsed.raw.claude ? marked.parse(parsed.raw.claude) : '<em style=\"color:#475569\">no response</em>';\n    $gpt.innerHTML = parsed.raw.gpt ? marked.parse(parsed.raw.gpt) : '<em style=\"color:#475569\">no response</em>';\n    $gemini.innerHTML = parsed.raw.gemini ? marked.parse(parsed.raw.gemini) : '<em style=\"color:#475569\">no response</em>';\n    $grok.innerHTML = parsed.raw.grok ? marked.parse(parsed.raw.grok) : '<em style=\"color:#475569\">no response</em>';\n  }\n\n  function renderThreadList() {\n    if (threads.length === 0) {\n      $threadList.innerHTML = '<div class=\"empty-list\">No threads yet. Ask a question.</div>';\n      return;\n    }\n    const sorted = [...threads].sort((a, b) => b.timestamp - a.timestamp);\n    $threadList.innerHTML = sorted.map(t => `\n      <div class=\"thread-item ${t.id === activeThreadId ? 'active' : ''} ${t.inProgress ? 'in-progress' : ''}\" data-id=\"${t.id}\">\n        <div class=\"question-preview\">${escapeHtml(t.question)}</div>\n        <div class=\"meta\">\n          <span>${formatRelative(t.timestamp)}</span>\n          <span class=\"actions\">\n            <button class=\"action-btn copy\" data-action=\"copy\" data-id=\"${t.id}\" title=\"Copy markdown\">\u29c9</button>\n            <button class=\"action-btn download\" data-action=\"download\" data-id=\"${t.id}\" title=\"Download .md\">\u2193</button>\n            <button class=\"action-btn delete\" data-action=\"delete\" data-id=\"${t.id}\" title=\"Delete\">\u00d7</button>\n          </span>\n        </div>\n      </div>\n    `).join('');\n  }\n\n  function escapeHtml(str) {\n    return String(str).replace(/[&<>\"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#039;'}[c]));\n  }\n\n  function selectThread(id) {\n    const t = threads.find(x => x.id === id);\n    if (!t) return;\n    activeThreadId = id;\n    location.hash = id;\n    $answerHeader.classList.add('active');\n    $answerQ.textContent = t.question;\n    $empty.classList.add('hidden');\n    $error.classList.remove('active');\n    if (t.inProgress) {\n      $loading.classList.add('active');\n      $status.textContent = 'In progress...';\n    } else {\n      $loading.classList.remove('active');\n    }\n    if (t.answer) {\n      $results.classList.add('active');\n      renderAnswer(t.answer);\n    } else {\n      $results.classList.remove('active');\n    }\n    renderThreadList();\n    // close mobile sidebar\n    $sidebar.classList.remove('open');\n    $sidebarOverlay.classList.remove('open');\n  }\n\n  function newThread() {\n    activeThreadId = null;\n    location.hash = '';\n    $answerHeader.classList.remove('active');\n    $results.classList.remove('active');\n    $empty.classList.remove('hidden');\n    $error.classList.remove('active');\n    $loading.classList.remove('active');\n    $question.value = '';\n    $question.focus();\n    renderThreadList();\n    $sidebar.classList.remove('open');\n    $sidebarOverlay.classList.remove('open');\n  }\n\n  function buildMarkdown(thread) {\n    const date = new Date(thread.timestamp).toLocaleString();\n    let md = `# Council answer \u2014 ${date}\\n\\n`;\n    md += `## Question\\n\\n${thread.question}\\n\\n---\\n\\n`;\n    md += thread.answer || '_(no answer)_';\n    md += `\\n\\n---\\n\\n_Session: ${sessionId}_\\n_InstaBid AI Council_`;\n    return md;\n  }\n\n  function copyThread(id) {\n    const t = threads.find(x => x.id === id);\n    if (!t) return;\n    navigator.clipboard.writeText(buildMarkdown(t))\n      .then(() => showToast('Copied to clipboard \u2713', 'success'))\n      .catch(() => showToast('Copy failed \u2014 your browser blocked clipboard access'));\n  }\n\n  function downloadThread(id) {\n    const t = threads.find(x => x.id === id);\n    if (!t) return;\n    const md = buildMarkdown(t);\n    const blob = new Blob([md], { type: 'text/markdown' });\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a');\n    const slug = t.question.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 40).replace(/^-|-$/g, '');\n    const dateStr = new Date(t.timestamp).toISOString().slice(0, 10);\n    a.download = `council-${dateStr}-${slug}.md`;\n    a.href = url;\n    a.click();\n    URL.revokeObjectURL(url);\n    showToast('Downloaded \u2713', 'success');\n  }\n\n  function deleteThread(id) {\n    if (!confirm('Delete this thread?')) return;\n    threads = threads.filter(t => t.id !== id);\n    saveThreads(threads);\n    if (activeThreadId === id) newThread();\n    else renderThreadList();\n    showToast('Thread deleted');\n  }\n\n  // Elapsed timer\n  let elapsedInterval = null;\n  function startTimer() {\n    const start = Date.now();\n    $elapsed.textContent = '0.0s';\n    elapsedInterval = setInterval(() => {\n      $elapsed.textContent = ((Date.now() - start) / 1000).toFixed(1) + 's';\n    }, 100);\n  }\n  function stopTimer() { if (elapsedInterval) { clearInterval(elapsedInterval); elapsedInterval = null; } }\n\n  async function askCouncil(question) {\n    // Create thread entry\n    const threadId = uid();\n    const newT = { id: threadId, question, answer: '', timestamp: Date.now(), inProgress: true };\n    threads.unshift(newT);\n    saveThreads(threads);\n    activeThreadId = threadId;\n    location.hash = threadId;\n\n    // Update UI\n    $error.classList.remove('active');\n    $empty.classList.add('hidden');\n    $loading.classList.add('active');\n    $status.textContent = 'Routing to four models...';\n    $send.disabled = true;\n    $answerHeader.classList.add('active');\n    $answerQ.textContent = question;\n    $results.classList.add('active');\n    $claude.innerHTML = '<em style=\"color:#475569\">streaming...</em>';\n    $gpt.innerHTML = '<em style=\"color:#475569\">streaming...</em>';\n    $gemini.innerHTML = '<em style=\"color:#475569\">streaming...</em>';\n    $grok.innerHTML = '<em style=\"color:#475569\">streaming...</em>';\n    $consensus.innerHTML = '<em style=\"color:#94a3b8\">synthesizing...</em>';\n    $dissentLabel.style.display = 'none';\n    $dissentCard.style.display = 'none';\n    renderThreadList();\n    startTimer();\n\n    try {\n      const res = await fetch(WEBHOOK_URL, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ chatInput: question, sessionId })\n      });\n\n      if (!res.ok) throw new Error('HTTP ' + res.status + ': ' + await res.text());\n      if (!res.body) throw new Error('No response body');\n\n      const reader = res.body.getReader();\n      const decoder = new TextDecoder();\n      let buffer = '';\n      let accumulated = '';\n      let chunkCount = 0;\n\n      while (true) {\n        const { done, value } = await reader.read();\n        if (done) break;\n        buffer += decoder.decode(value, { stream: true });\n        const lines = buffer.split('\\n');\n        buffer = lines.pop() || '';\n\n        for (const line of lines) {\n          const trimmed = line.trim();\n          if (!trimmed) continue;\n          try {\n            const obj = JSON.parse(trimmed);\n            if (obj.type === 'item' && obj.content) {\n              accumulated += obj.content;\n              chunkCount++;\n              $status.textContent = 'Streaming \u00b7 ' + chunkCount + ' chunks \u00b7 ' + accumulated.length + ' chars';\n              renderAnswer(accumulated);\n            } else if (obj.type === 'begin') {\n              $status.textContent = 'Models started \u00b7 synthesizing...';\n            } else if (obj.type === 'end') {\n              $status.textContent = 'Complete';\n            }\n          } catch (e) {}\n        }\n      }\n      if (buffer.trim()) {\n        try {\n          const obj = JSON.parse(buffer.trim());\n          if (obj.type === 'item' && obj.content) accumulated += obj.content;\n        } catch (e) {}\n      }\n\n      renderAnswer(accumulated);\n\n      // Save final answer\n      const idx = threads.findIndex(t => t.id === threadId);\n      if (idx !== -1) {\n        threads[idx].answer = accumulated;\n        threads[idx].inProgress = false;\n        threads[idx].timestamp = Date.now();\n        saveThreads(threads);\n      }\n\n      $status.textContent = '\u2713 Complete';\n      renderThreadList();\n      setTimeout(() => $loading.classList.remove('active'), 800);\n\n    } catch (err) {\n      console.error(err);\n      $error.textContent = 'Error: ' + (err.message || 'Unknown error');\n      $error.classList.add('active');\n      $loading.classList.remove('active');\n      const idx = threads.findIndex(t => t.id === threadId);\n      if (idx !== -1) {\n        threads[idx].inProgress = false;\n        threads[idx].answer = '_(error: ' + (err.message || 'unknown') + ')_';\n        saveThreads(threads);\n        renderThreadList();\n      }\n    } finally {\n      stopTimer();\n      $send.disabled = false;\n    }\n  }\n\n  // Events\n  $send.addEventListener('click', () => {\n    const q = $question.value.trim();\n    if (!q) { $question.focus(); return; }\n    askCouncil(q);\n    $question.value = '';\n  });\n\n  $question.addEventListener('keydown', (e) => {\n    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {\n      e.preventDefault();\n      $send.click();\n    }\n  });\n\n  $newBtn.addEventListener('click', newThread);\n\n  // Sidebar event delegation\n  $threadList.addEventListener('click', (e) => {\n    const actionBtn = e.target.closest('[data-action]');\n    if (actionBtn) {\n      e.stopPropagation();\n      const action = actionBtn.dataset.action;\n      const id = actionBtn.dataset.id;\n      if (action === 'copy') copyThread(id);\n      else if (action === 'download') downloadThread(id);\n      else if (action === 'delete') deleteThread(id);\n      return;\n    }\n    const item = e.target.closest('.thread-item');\n    if (item) selectThread(item.dataset.id);\n  });\n\n  // Answer header actions\n  $copyBtn.addEventListener('click', () => { if (activeThreadId) copyThread(activeThreadId); });\n  $downloadBtn.addEventListener('click', () => { if (activeThreadId) downloadThread(activeThreadId); });\n\n  // Mobile sidebar toggle\n  $sidebarToggle.addEventListener('click', () => {\n    $sidebar.classList.toggle('open');\n    $sidebarOverlay.classList.toggle('open');\n  });\n  $sidebarOverlay.addEventListener('click', () => {\n    $sidebar.classList.remove('open');\n    $sidebarOverlay.classList.remove('open');\n  });\n\n  // Hash routing \u2014 open thread by URL hash\n  function handleHash() {\n    const id = location.hash.replace(/^#/, '');\n    if (id && threads.find(t => t.id === id)) selectThread(id);\n  }\n  window.addEventListener('hashchange', handleHash);\n\n  // Init\n  renderThreadList();\n  handleHash();\n  $question.focus();\n</script>\n</body>\n</html>\n",
